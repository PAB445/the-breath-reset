# OS
.DS_Store
Thumbs.db

# Dev / test artifacts
output/
.playwright-cli/
tmp/master-*.wav
tmp/*.wav
tmp/test_*.mp4
tmp/frame_*.png
tmp/reel_test_*.mp4

# Social-only assets (not referenced by the website)
# Website uses: assets/social/instagram/practices/<slug>/reel.mp4 + cover.png
#              assets/social/youtube/founder-video/founder-story.mp4 + cover/end PNGs
#              assets/social/youtube/retrain/breath-hold-test/Retrain_BreathHoldTest_Final.mp4 + cover/end PNGs

# Long-form YouTube exports (~5 min, 16:9) — upload to YouTube separately
assets/social/youtube/long/
assets/social/youtube/relax/long/

# YouTube Shorts — copies of the Instagram reels; regenerate via render_reel.py
assets/social/youtube/shorts/
assets/social/youtube/relax/shorts/

# Retrain YouTube working/final exports not embedded on the website
assets/social/youtube/retrain/breath-hold-test/*.mp4
!assets/social/youtube/retrain/breath-hold-test/Retrain_BreathHoldTest_Final.mp4

# Founder source exports; keep the site-ready MP4 tracked instead
assets/social/youtube/founder-video/*.mov

# End cards (baked into videos; cover.png is the site poster)
assets/social/instagram/practices/*/end.png

# Static PNG decks for manual CapCut / Instagram assembly
assets/social/instagram/reel-frames/
assets/social/instagram/carousels/
assets/social/instagram/posts/
